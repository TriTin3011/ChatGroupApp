<Window x:Class="ChatGroupApp.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ChatGroupApp Client"
        Height="620"
        MinHeight="520"
        Width="920"
        MinWidth="760"
        Closing="Window_Closing">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Background="#F5F7FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="#D7DDE8"
                BorderThickness="0,0,0,1"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="IP Server" FontWeight="SemiBold" />
                    <TextBox x:Name="ServerIpTextBox" Text="127.0.0.1" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Port" FontWeight="SemiBold" />
                    <TextBox x:Name="PortTextBox" Text="5000" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="Ten cua ban" FontWeight="SemiBold" />
                    <TextBox x:Name="UserNameTextBox" Text="Student" />
                </StackPanel>

                <Button x:Name="ConnectButton"
                        Grid.Column="3"
                        Width="110"
                        Margin="0,17,8,0"
                        Click="ConnectButton_Click"
                        Content="Ket noi" />

                <Button x:Name="DisconnectButton"
                        Grid.Column="4"
                        Width="110"
                        Margin="0,17,0,0"
                        Click="DisconnectButton_Click"
                        Content="Ngat"
                        IsEnabled="False" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="StatusTextBlock"
                       Grid.Row="0"
                       Margin="0,0,0,10"
                       Foreground="#4D5A6B"
                       Text="Chua ket noi server." />

            <Border Grid.Row="1"
                    Background="#FFFFFF"
                    BorderBrush="#D7DDE8"
                    BorderThickness="1"
                    CornerRadius="8">
                <ListBox x:Name="MessagesListBox"
                         BorderThickness="0"
                         FontFamily="Segoe UI Emoji, Segoe UI"
                         FontSize="15"
                         Padding="10">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,3"
                                    Padding="10,8"
                                    Background="{Binding Background}"
                                    CornerRadius="7"
                                    HorizontalAlignment="{Binding Alignment}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Sender}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#566173" />
                                    <TextBlock Text="{Binding Text}"
                                               FontSize="15"
                                               Foreground="#172033"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="#D7DDE8"
                BorderThickness="0,1,0,0"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <UniformGrid x:Name="EmojiPanel"
                             Grid.Row="0"
                             Columns="12"
                             Margin="0,0,0,10"
                             Visibility="Collapsed" />

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="EmojiButton"
                            Grid.Column="0"
                            Width="48"
                            Margin="0,0,8,0"
                            Click="EmojiButton_Click"
                            Content="😊"
                            ToolTip="Mo emoji" />

                    <TextBox x:Name="MessageTextBox"
                             Grid.Column="1"
                             AcceptsReturn="False"
                             IsEnabled="False"
                             KeyDown="MessageTextBox_KeyDown" />

                    <Button x:Name="SendButton"
                            Grid.Column="2"
                            Width="110"
                            Margin="8,0,0,0"
                            Click="SendButton_Click"
                            Content="Gui"
                            IsEnabled="False" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
